# LLM providers — add only the keys you use
OPENAI_API_KEY=
# Gemini: set either GOOGLE_API_KEY or GEMINI_API_KEY (both accepted)
GOOGLE_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Embedding backend: "local" (default, no cost) | "openai"
EMBEDDING_BACKEND=local

# Storage paths (defaults work out-of-the-box relative to backend/)
CHROMA_DATA_DIR=../chroma_data
UPLOAD_DIR=../uploads
SQLITE_URL=sqlite:///../chatpdf.db
EVAL_GOLD_PATH=../eval/gold.json   # persisted RAG-eval gold set

# Comma-separated allowed CORS origins
# Docker: CORS_ORIGINS=http://localhost
CORS_ORIGINS=http://localhost:5173

# ── Resource bounds (DoS / cost / context guards) ───────────────────────────
MAX_UPLOAD_MB=50              # reject PDFs larger than this
MAX_QUERY_CHARS=8000          # reject oversized chat queries
MAX_DOCS_PER_SESSION=50       # cap retrieval fan-out per session
MAX_HISTORY_MESSAGES=20       # window chat history into the prompt (≈10 turns)

# ── LLM behaviour ───────────────────────────────────────────────────────────
LLM_MAX_RETRIES=2             # provider-SDK retries for transient (429/5xx) errors
WARM_RERANKER_ON_STARTUP=false  # preload the cross-encoder at boot (slower start)

# ── Langfuse observability (optional, free) ─────────────────────────────────
# When both keys are set, every LLM call (chat / eval answer / judge / query
# expansion) is traced with latency, token usage, and cost, and eval metrics
# are pushed as scores. Unset → fully disabled, no network calls.
# Get free keys at https://cloud.langfuse.com (Hobby tier, no card).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com   # or https://us.cloud.langfuse.com / self-host URL
